    "print(\"📝 TO-DO LIST DEMO\")\nprint(\"=\" * 50)\n\n# Add sample tasks\ntasks = [\n    (\"Learn Python\", \"high\"),\n    (\"Complete Colab notebook\", \"high\"),\n    (\"Buy groceries\", \"medium\"),\n    (\"Exercise\", \"low\"),\n    (\"Read documentation\", \"medium\"),\n]\n\nprint(\"\\n📌 Adding tasks...\")\nfor title, priority in tasks:\n    todo.add_task(title, priority)\n    print(f\"  ✓ Added: {title} (Priority: {priority})\")\n\n# Display all tasks\nprint(\"\\n📋 All Tasks:\")\nfor task in todo.list_tasks():\n    status = \"✓ DONE\" if task['completed'] else \"⏳ PENDING\"\n    print(f\"  [{task['id']}] {task['title']} - {task['priority'].upper()} - {status}\")\n\n# Complete some tasks\nprint(\"\\n✅ Completing tasks...\")\ntodo.complete_task(1)\ntodo.complete_task(3)\nprint(\"  ✓ Task 1 completed\")\nprint(\"  ✓ Task 3 completed\")\n\n# Show pending\nprint(\"\\n⏳ Pending Tasks:\")\nfor task in todo.get_pending():\n    print(f\"  [{task['id']}] {task['title']} - {task['priority'].upper()}\")\n\n# Statistics\nprint(\"\\n📊 Statistics:\")\nstats = todo.get_statistics()\nfor key, value in stats.items():\n    print(f\"  {key.replace('_', ' ').title()}: {value}\")"
