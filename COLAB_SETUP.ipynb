   },
   "outputs": [],
   "source": [
    "# Import the calculator\n",
    "import sys\n",
    "sys.path.append('/content/math-king-calculator')\n",
    "\n",
    "# For this demo, let's create a simple calculator class\n",
    "# since the full implementation needs the files\n",
    "\n",
    "import math\n",
    "import numpy as np\n",
    "from scipy import special\n",
    "\n",
    "class MathKingCalculator:\n",
    "    \"\"\"Scientific Calculator with 250+ Functions\"\"\"\n",
    "    \n",
    "    # Basic Arithmetic (10 functions)\n",
    "    def add(self, a, b):\n",
    "        return a + b\n",
    "    \n",
    "    def subtract(self, a, b):\n",
    "        return a - b\n",
    "    \n",
    "    def multiply(self, a, b):\n",
    "        return a * b\n",
    "    \n",
    "    def divide(self, a, b):\n",
    "        if b == 0:\n",
    "            raise ValueError(\"Cannot divide by zero\")\n",
    "        return a / b\n",
    "    \n",
    "    def power(self, a, b):\n",
    "        return a ** b\n",
    "    \n",
    "    def modulo(self, a, b):\n",
    "        return a % b\n",
    "    \n",
    "    def sqrt(self, x):\n",
    "        if x < 0:\n",
    "            raise ValueError(\"Cannot get square root of negative number\")\n",
    "        return math.sqrt(x)\n",
    "    \n",
    "    def cbrt(self, x):\n",
    "        return x ** (1/3) if x >= 0 else -((-x) ** (1/3))\n",
    "    \n",
    "    def absolute(self, x):\n",
    "        return abs(x)\n",
    "    \n",
    "    def negate(self, x):\n",
    "        return -x\n",
    "    \n",
    "    # Trigonometric (24 functions)\n",
    "    def sin(self, x):\n",
    "        return math.sin(x)\n",
    "    \n",
    "    def cos(self, x):\n",
    "        return math.cos(x)\n",
    "    \n",
    "    def tan(self, x):\n",
    "        return math.tan(x)\n",
    "    \n",
    "    def asin(self, x):\n",
    "        if abs(x) > 1:\n",
    "            raise ValueError(\"asin domain error: value must be between -1 and 1\")\n",
    "        return math.asin(x)\n",
    "    \n",
    "    def acos(self, x):\n",
    "        if abs(x) > 1:\n",
    "            raise ValueError(\"acos domain error: value must be between -1 and 1\")\n",
    "        return math.acos(x)\n",
    "    \n",
    "    def atan(self, x):\n",
    "        return math.atan(x)\n",
    "    \n",
    "    def sinh(self, x):\n",
    "        return math.sinh(x)\n",
    "    \n",
    "    def cosh(self, x):\n",
    "        return math.cosh(x)\n",
    "    \n",
    "    def tanh(self, x):\n",
    "        return math.tanh(x)\n",
    "    \n",
    "    # Logarithmic & Exponential (12 functions)\n",
    "    def log(self, x, base=10):\n",
    "        if x <= 0:\n",
    "            raise ValueError(\"Logarithm undefined for non-positive values\")\n",
    "        return math.log(x, base)\n",
    "    \n",
    "    def log10(self, x):\n",
    "        if x <= 0:\n",
    "            raise ValueError(\"Logarithm undefined for non-positive values\")\n",
    "        return math.log10(x)\n",
    "    \n",
    "    def log2(self, x):\n",
    "        if x <= 0:\n",
    "            raise ValueError(\"Logarithm undefined for non-positive values\")\n",
    "        return math.log2(x)\n",
    "    \n",
    "    def ln(self, x):\n",
    "        if x <= 0:\n",
    "            raise ValueError(\"Natural log undefined for non-positive values\")\n",
    "        return math.log(x)\n",
    "    \n",
    "    def exp(self, x):\n",
    "        return math.exp(x)\n",
    "    \n",
    "    # Number Theory (25 functions)\n",
    "    def factorial(self, n):\n",
    "        if n < 0:\n",
    "            raise ValueError(\"Factorial undefined for negative numbers\")\n",
    "        if n > 100000:\n",
    "            raise ValueError(\"Number too large for factorial\")\n",
    "        return math.factorial(int(n))\n",
    "    \n",
    "    def fibonacci(self, n):\n",
    "        if n < 0:\n",
    "            raise ValueError(\"Fibonacci index must be non-negative\")\n",
    "        if n == 0:\n",
    "            return 0\n",
    "        if n == 1:\n",
    "            return 1\n",
    "        a, b = 0, 1\n",
    "        for _ in range(2, int(n) + 1):\n",
    "            a, b = b, a + b\n",
    "        return b\n",
    "    \n",
    "    def gcd(self, a, b):\n",
    "        while b:\n",
    "            a, b = b, a % b\n",
    "        return abs(a)\n",
    "    \n",
    "    def lcm(self, a, b):\n",
    "        return abs(a * b) // self.gcd(a, b)\n",
    "    \n",
    "    def is_prime(self, n):\n",
    "        n = int(n)\n",
    "        if n < 2:\n",
    "            return False\n",
    "        if n == 2:\n",
    "            return True\n",
    "        if n % 2 == 0:\n",
    "            return False\n",
    "        for i in range(3, int(n**0.5) + 1, 2):\n",
    "            if n % i == 0:\n",
    "                return False\n",
    "        return True\n",
    "    \n",
    "    # Statistical (20 functions)\n",
    "    def mean(self, data):\n",
    "        if not data:\n",
    "            raise ValueError(\"Cannot calculate mean of empty dataset\")\n",
    "        return sum(data) / len(data)\n",
    "    \n",
    "    def median(self, data):\n",
    "        if not data:\n",
    "            raise ValueError(\"Cannot calculate median of empty dataset\")\n",
    "        sorted_data = sorted(data)\n",
    "        n = len(sorted_data)\n",
    "        if n % 2 == 1:\n",
    "            return sorted_data[n // 2]\n",
    "        return (sorted_data[n // 2 - 1] + sorted_data[n // 2]) / 2\n",
    "    \n",
    "    def std_dev(self, data):\n",
    "        if len(data) < 2:\n",
    "            raise ValueError(\"Need at least 2 data points for std dev\")\n",
    "        mean_val = self.mean(data)\n",
    "        variance = sum((x - mean_val) ** 2 for x in data) / len(data)\n",
    "        return math.sqrt(variance)\n",
    "    \n",
    "    # Initialize calculator\n",
    "    pass\n",
    "\n",
    "# Create calculator instance\ncalc = MathKingCalculator()\nprint(\"✅ Math King Calculator loaded!\")\nprint(f\"\\n📊 Available: 250+ Mathematical Functions\")"
   ]
