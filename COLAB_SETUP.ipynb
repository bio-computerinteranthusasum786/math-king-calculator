    "# Advanced Example 3: Trigonometric Functions Visualization\nprint(\"📐 TRIGONOMETRIC FUNCTIONS COMPARISON\")\nprint(\"=\" * 50)\n\nfig, axes = plt.subplots(2, 2, figsize=(12, 8))\n\nx = np.linspace(0, 2*np.pi, 200)\n\n# Sin\nax = axes[0, 0]\ny = [calc.sin(val) for val in x]\nax.plot(x, y, 'b-', linewidth=2)\nax.fill_between(x, y, alpha=0.3)\nax.set_title('sin(x)', fontsize=12, fontweight='bold')\nax.grid(True, alpha=0.3)\nax.set_ylim(-1.5, 1.5)\n\n# Cos\nax = axes[0, 1]\ny = [calc.cos(val) for val in x]\nax.plot(x, y, 'r-', linewidth=2)\nax.fill_between(x, y, alpha=0.3)\nax.set_title('cos(x)', fontsize=12, fontweight='bold')\nax.grid(True, alpha=0.3)\nax.set_ylim(-1.5, 1.5)\n\n# Tan\nax = axes[1, 0]\ny = [calc.tan(val) if abs(calc.tan(val)) < 10 else np.nan for val in x]\nax.plot(x, y, 'g-', linewidth=2)\nax.set_title('tan(x)', fontsize=12, fontweight='bold')\nax.grid(True, alpha=0.3)\nax.set_ylim(-10, 10)\n\n# All together\nax = axes[1, 1]\nax.plot(x, [calc.sin(val) for val in x], 'b-', label='sin(x)', linewidth=2)\nax.plot(x, [calc.cos(val) for val in x], 'r-', label='cos(x)', linewidth=2)\nax.set_title('sin(x) vs cos(x)', fontsize=12, fontweight='bold')\nax.legend()\nax.grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.show()"
   ]
